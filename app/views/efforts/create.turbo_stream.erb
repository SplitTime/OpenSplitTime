<%# locals: (effort:, presenter:) %>

<%= turbo_stream.replace("form_modal", "") %>

<%= turbo_stream.replace("entrants_callout",
                         partial: "event_groups/entrants_callout",
                         locals: { presenter: presenter }) %>

<%= turbo_stream.update("entrants_count",
                        html: filter_count_text(presenter.filtered_efforts_total_count, presenter.event_group_efforts_count, "entrant")) %>

<%= turbo_stream.prepend("entrants",
                         partial: "efforts/entrant_for_setup",
                         locals: { presenter: presenter, effort: effort }) %>
