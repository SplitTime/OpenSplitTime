<%# locals: (effort:, presenter:) %>

<%= turbo_stream.remove(dom_id(effort, :event_group_setup)) %>

<%= turbo_stream.replace("unreconciled_callout",
                         partial: "event_groups/unreconciled_callout",
                         locals: { presenter: presenter }) %>

<%= turbo_stream.replace("entrants_callout",
                         partial: "event_groups/entrants_callout",
                         locals: { presenter: presenter }) %>

<%= turbo_stream.replace("entrants_count",
                         partial: "event_groups/entrants_count",
                         locals: { presenter: presenter }) %>
