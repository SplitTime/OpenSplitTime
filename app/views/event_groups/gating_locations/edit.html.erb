<% content_for :title do %>
  <% "OpenSplitTime: Edit Gating Location - #{@gating_location.name}" %>
<% end %>

<%= render "shared/mode_widget", event_group: @event_group %>

<header class="ost-header">
  <div class="container">
    <div class="ost-heading row">
      <div class="col">
        <div class="ost-title">
          <h1><strong>Edit Gating Location - <%= @gating_location.name %></strong></h1>
          <ul class="breadcrumb breadcrumb-ost">
            <li class="breadcrumb-item"><%= link_to "Organizations", organizations_path %></li>
            <li class="breadcrumb-item"><%= link_to @event_group.organization.name, organization_path(@event_group.organization) %></li>
            <li class="breadcrumb-item"><%= link_to @event_group.name, organization_event_group_path(@event_group.organization, @event_group) %></li>
            <li class="breadcrumb-item"><%= link_to "Crew Gating", organization_event_group_gating_locations_path(@event_group.organization, @event_group) %></li>
            <li class="breadcrumb-item">Edit</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</header>

<article class="ost-article container">
  <%= render "form" %>
</article>
