<% content_for :title do %>
  <% "OpenSplitTime: Crew Access - #{@display.name}" %>
<% end %>

<header class="ost-header">
  <div class="container">
    <div class="ost-heading row">
      <div class="col">
        <div class="ost-title">
          <h1 class="fw-bold">Crew Access: <%= @display.name %></h1>
          <ul class="breadcrumb breadcrumb-ost">
            <li class="breadcrumb-item"><%= link_to "Organizations", organizations_path %></li>
            <li class="breadcrumb-item"><%= link_to @presenter.organization.name, organization_path(@presenter.organization) %></li>
            <li class="breadcrumb-item"><%= link_to @presenter.event_group.name, event_group_path(@presenter.event_group) %></li>
            <li class="breadcrumb-item"><%= link_to "Crew Access", live_event_group_gating_locations_path(@presenter.event_group) %></li>
            <li class="breadcrumb-item active"><%= @display.name %></li>
          </ul>
        </div>
      </div>
    </div>
    <%= render "events/view_buttons", view_object: @presenter %>
  </div>
</header>

<article class="ost-article container">
  <% @display.gated_events.each do |gating_location_event| %>
    <%= render "live/gating_locations/gated_event", gating_location_event: gating_location_event, display: @display %>
  <% end %>
</article>
