<nav>
  <h1 class="text-xl font-semibold mb-4">Madmin</h1>

  <% if main_app.respond_to?(:root_url) %>
    <%= link_to main_app.root_url, class: "block mb-4", data: { turbo: false } do %>
      ← Back to App
    <% end %>
  <% end %>

  <%= nav_link_to "Dashboard", madmin_root_path, class: "block mb-2" %>

  <% Madmin.menu.render do |item| %>
    <% if item.url %>
      <%= nav_link_to item.label, item.url, starts_with: item.url, class: "block mb-1" %>
    <% else %>
      <h4 class="font-semibold mt-4 mb-2"><%= item.label %></h4>
    <% end %>

    <% item.items.each do |child| %>
      <%= nav_link_to child.label, child.url, starts_with: child.url, class: "block mb-1 ml-2" %>
    <% end %>
  <% end %>
</nav>
