<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <h1 class="text-3xl font-bold mb-6">OpenSplitTime Admin Dashboard</h1>
  
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <div class="bg-white rounded-lg shadow p-6">
      <h3 class="text-lg font-semibold mb-2">Events</h3>
      <p class="text-3xl font-bold text-blue-600"><%= Event.count %></p>
    </div>
    
    <div class="bg-white rounded-lg shadow p-6">
      <h3 class="text-lg font-semibold mb-2">Efforts</h3>
      <p class="text-3xl font-bold text-green-600"><%= Effort.count %></p>
    </div>
    
    <div class="bg-white rounded-lg shadow p-6">
      <h3 class="text-lg font-semibold mb-2">Users</h3>
      <p class="text-3xl font-bold text-purple-600"><%= User.count %></p>
    </div>
  </div>
  
  <div class="mt-8 bg-white rounded-lg shadow p-6">
    <h2 class="text-xl font-semibold mb-4">Recent Activity</h2>
    <p class="text-gray-600">Recent events and activities will appear here.</p>
  </div>
</div>
