<% content_for :robots_meta, "nofollow" %>
<% content_for :title do %>
    <% if params[:search].present? %>
        <% "OpenSplitTime: Search people - #{params[:search]}" %>
    <% else %>
        <% "OpenSplitTime: Search people" %>
    <% end %>
<% end %>

<header class="ost-header">
  <div class="container">
    <div class="ost-heading row">
      <div class="ost-title col">
        <div class="h1 fw-bold">People</div>
        <ul class="breadcrumb breadcrumb-ost">
          <li class="breadcrumb-item active">People</li>
        </ul>
      </div>
    </div>
  </div>
</header>

<aside class="ost-toolbar">
  <div class="container">
    <div class="row">
      <div class="col-12 col-md-6">
        <%= render "lookup" %>
      </div>
      </div>
    </div>
  </div>
</aside>

<article class="ost-article container">
  <% if @presenter.people.present? %>
    <%= render "people_list", presenter: @presenter %>
    <%= render "shared/pager", next_page_url: @presenter.next_page_url %>
  <% else %>
    <br/>
    <% if prepared_params[:search].blank? %>
      <p><strong>Find someone by entering a name, state, or country</strong></p>
    <% elsif prepared_params[:search].length < 3 %>
      <p><strong>Search parameter is too short</strong></p>
    <% else %>
      <p><strong>No people match this search</strong></p>
    <% end %>
  <% end %>
</article>
